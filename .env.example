POSTGRES_USER=ledgerguard
POSTGRES_PASSWORD=ledgerguard
POSTGRES_DB=ledgerguard
JWT_SECRET=change-me-to-a-long-random-string
API_RATE_LIMIT=600
API_RATE_WINDOW_MS=60000

# simulator/replay.js env vars
# default send rate in transactions per second
RATE_PER_SECOND=2
# maximum retry attempts when receiving HTTP 429
MAX_TXN_ATTEMPTS=5
# base retry delay in milliseconds when Retry-After is not provided
BASE_RETRY_MS=500
